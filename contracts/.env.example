# Copy to repo root as `.env` (or export in your shell). Do not commit real keystores or secrets.
#
# Shared Starkli configuration (used by contracts/deploy-sepolia.sh and contracts/deploy-stack.sh)
STARKNET_KEYSTORE=/path/to/deployer_keystore.json
STARKNET_ACCOUNT=/path/to/deployer_account.json
STARKNET_NETWORK=sepolia
# Prefer an explicit RPC (overrides STARKNET_NETWORK for starkli --rpc):
STARKNET_RPC=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/<ALCHEMY_API_KEY>
# STARKNET_RPC_URL=   # alias of STARKNET_RPC

# Optional: deployer ContractAddress for mock constructors if not parsed from STARKNET_ACCOUNT (requires jq)
# DEPLOYER_ADDRESS=0x...

# --- deploy-sepolia.sh (UTTT only) ---
# TICTACTOE_GAME_CREATOR=0x...   # authorized create_game_for caller
# TICTACTOE_CLASS_HASH=         # skip declare if set
# TICTACTOE_DEFAULT_MOVE_TIMEOUT_SECS=86400
# TICTACTOE_POLL_INTERVAL_SECONDS=5
# TICTACTOE_MAX_CLASS_WAIT_ATTEMPTS=24

# --- deploy-stack.sh (mock reference stack) ---
# Deploy mock ERC20 and use it as wager_escrow approved_token; otherwise set WAGER_ESCROW_APPROVED_TOKEN.
# DEPLOY_MOCK_TOKEN=false
# WAGER_ESCROW_APPROVED_TOKEN=0x...
# WAGER_ESCROW_FEE_BPS=0
# WAGER_ESCROW_FEE_RECIPIENT=0x0
# MOCK_TOKEN_OWNER=0x...       # mock_erc20 constructor; defaults to deployer
# MOCK_ADAPTER_OWNER=0x...     # mock_game_adapter constructor; defaults to deployer
# TICTACTOE_DEFAULT_MOVE_TIMEOUT_SECS=86400
# Optional: skip declare if class already on chain
# MOCK_ERC20_CLASS_HASH=
# MOCK_GAME_ADAPTER_CLASS_HASH=
# TICTACTOE_CLASS_HASH=
# WAGER_ESCROW_CLASS_HASH=
